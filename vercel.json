{
  "version": 2,
  "builds": [
    {
      "src": "machine-api/server.js",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "appearance/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/appearance/assets/$1" },
    { "src": "/(.*)", "dest": "machine-api/server.js" }
  ],
  "functions": {
    "machine-api/server.js": {
      "maxDuration": 60
    }
  }
}
